extends ./layout/index

block cuerpocontenido

  // HERO
  .hero.p-5.text-center.mb-5
    h1.display-4 Bienvenido #{usuario ? usuario.correo : "Entrenador"}
    p.lead Compra y vende Pokémon 

    if !usuario
      a.btn.btn-primary.mt-3(href="/") Iniciar sesión
    else
      a.btn.btn-warning.mt-3(href="/inicio/lista-pokemon") Ver catálogo

  // PANEL POR ROL
  .row.text-center.mb-5
    if usuario && usuario.rol === 'admin'
      .col-md-4
        .card.p-4.shadow
          h3 Centro de Control
          p Administra usuarios y sistema

    if usuario && usuario.rol === 'vendedor'
      .col-md-4
        .card.p-4.shadow
          h3  Panel de Vendedor
          p Gestiona tus Pokémon

    if usuario && usuario.rol === 'comprador'
      .col-md-4
        .card.p-4.shadow
          h3  Panel de Comprador
          p Explora el catálogo

  // ACCIONES RÁPIDAS
  .row.text-center
    .col-md-3
      .card.p-3.shadow
        h5  Catálogo
        a.btn.btn-outline-primary(href="/inicio/lista-pokemon") Ver

    .col-md-3
      .card.p-3.shadow
        h5  Transacciones
        a.btn.btn-outline-success(href="/inicio/transacciones") Ver

    if usuario && (usuario.rol === 'admin' || usuario.rol === 'vendedor')
      .col-md-3
        .card.p-3.shadow
          h5 Nuevo Pokémon
          a.btn.btn-outline-warning(href="/inicio/alta-pokemon") Crear


  // SWEET ALERTS (igual que tenías)
  script(src="https://cdn.jsdelivr.net/npm/sweetalert2@11")

  if mensaje === 'compra_exitosa'
    script.
      Swal.fire({
        title: 'Éxito',
        text: 'Solicitud realizada correctamente',
        icon: 'success'
      });

  if mensaje === 'error'
    script.
      Swal.fire({
        title: 'Error',
        text: 'Algo salió mal',
        icon: 'error'
      });

  if mensaje === 'error_venta'
    script.
      Swal.fire('Error', 'Ocurrió un problema', 'error');
  
  if mensaje === 'venta_aprobada'
    script.
      Swal.fire('Éxito', 'Venta aprobada', 'success');
  
  if mensaje === 'venta_rechazada'
    script.
      Swal.fire('Info', 'Venta rechazada', 'info');

  if mensaje === 'pokemon_eliminado'
    script.
      Swal.fire('Éxito', 'Pokemon eliminado', 'info');